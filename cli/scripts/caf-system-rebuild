#!/bin/bash
set -euo pipefail

# Rebuilds the Cafaye distributed development infrastructure using Home Manager
# Usage: caf-system-rebuild

echo "🚀 Applying Cafaye Foundation Changes..."
export NIX_CONFIG="experimental-features = nix-command flakes"

DRY_RUN=0
if [[ "${1:-}" == "--dry-run" ]]; then
  DRY_RUN=1
fi

# Structured Logging
LOG_DIR="$HOME/.config/cafaye/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/rebuild.log"
LOG_LEVEL="${CAFAYE_LOG_LEVEL:-info}" # quiet|info|debug
if [[ "$LOG_LEVEL" == "quiet" ]]; then
    exec >>"$LOG_FILE" 2>&1
else
    exec > >(tee -a "$LOG_FILE") 2>&1
fi
[[ "$LOG_LEVEL" == "debug" ]] && set -x

echo "--- Rebuild started: $(date) [Trace: ${CAFAYE_TRACE_ID:-none}] [level: $LOG_LEVEL] ---"

CAFAYE_DIR="$HOME/.config/cafaye"
if [[ ! -d "$CAFAYE_DIR" ]]; then
    # Fallback to current directory for dev
    CAFAYE_DIR="$(pwd)"
fi

cd "$CAFAYE_DIR"

SYSTEM_ARCH=$(uname -m)
[[ "$SYSTEM_ARCH" == "arm64" ]] && SYSTEM_ARCH="aarch64"
SYSTEM_OS=$(uname -s | tr '[:upper:]' '[:lower:]')
[[ "$SYSTEM_OS" == "darwin" ]] && OS_SUFFIX="darwin" || OS_SUFFIX="linux"
FLAKE_CONFIG="${SYSTEM_ARCH}-${OS_SUFFIX}"

echo "🔨 Switching to flake: .#${FLAKE_CONFIG}"
git add -A || true
now_ms() {
    local ts
    ts="$(date +%s%3N 2>/dev/null || true)"
    if [[ "$ts" =~ ^[0-9]+$ ]]; then
        echo "$ts"
    else
        echo "$(( $(date +%s) * 1000 ))"
    fi
}
start_ms="$(now_ms)"

attempt=1
max_attempts=2
while true; do
    if [[ "$DRY_RUN" -eq 1 ]]; then
        if nix run --extra-experimental-features "nix-command flakes" nixpkgs#home-manager -- build --flake ".#${FLAKE_CONFIG}" --show-trace; then
            break
        fi
    else
        if nix run --extra-experimental-features "nix-command flakes" nixpkgs#home-manager -- switch --flake ".#${FLAKE_CONFIG}" -b "backup-$(date +%Y%m%d%H%M%S)" --show-trace; then
            break
        fi
    fi
    if [[ "$attempt" -ge "$max_attempts" ]]; then
        echo "❌ Rebuild failed after ${max_attempts} attempts."
        echo "Recovery options:"
        echo "  - Retry: caf apply"
        echo "  - Roll back: home-manager generations && home-manager switch --rollback"
        exit 1
    fi
    attempt=$((attempt + 1))
    echo "⚠️  Rebuild failed, retrying (${attempt}/${max_attempts})..."
done

end_ms="$(now_ms)"
duration_ms="$((end_ms - start_ms))"
if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "✅ Dry-run build successful in ${duration_ms}ms"
else
    echo "✅ Changes applied successfully in ${duration_ms}ms"
fi
