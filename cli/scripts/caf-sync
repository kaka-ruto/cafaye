#!/bin/bash
set -euo pipefail

# Cafaye Sync: Sync state between nodes via Git
# Usage: caf-sync [push|pull] [--dry-run]

CAFAYE_DIR="$HOME/.config/cafaye"
if [[ ! -d "$CAFAYE_DIR" ]]; then
    CAFAYE_DIR="$(pwd)"
fi

cd "$CAFAYE_DIR"

command="${1:-}"
dry_run=0
if [[ "${2:-}" == "--dry-run" ]] || [[ "${1:-}" == "--dry-run" ]]; then
    dry_run=1
fi

# Structured Logging
LOG_DIR="$HOME/.config/cafaye/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/sync.log"
LOG_LEVEL="${CAFAYE_LOG_LEVEL:-info}" # quiet|info|debug
if [[ "$LOG_LEVEL" == "quiet" ]]; then
    exec >>"$LOG_FILE" 2>&1
else
    exec > >(tee -a "$LOG_FILE") 2>&1
fi
[[ "$LOG_LEVEL" == "debug" ]] && set -x

echo "--- Sync $command started: $(date) [Trace: ${CAFAYE_TRACE_ID:-none}] [level: $LOG_LEVEL] ---"
now_ms() {
    local ts
    ts="$(date +%s%3N 2>/dev/null || true)"
    if [[ "$ts" =~ ^[0-9]+$ ]]; then
        echo "$ts"
    else
        echo "$(( $(date +%s) * 1000 ))"
    fi
}
start_ms="$(now_ms)"

case "$command" in
    push)
        echo "📤 Syncing changes to Git Source of Truth..."
        if [[ "$dry_run" -eq 1 ]]; then
            echo "🧪 Dry run: would stage, commit (if needed), and push current branch."
            exit 0
        fi
        git add -A || true
        # Check if there are changes to commit
        if ! git diff-index --quiet HEAD --; then
            git commit -m "Sync: environment update from $(hostname)"
        fi
        current_branch="$(git rev-parse --abbrev-ref HEAD)"
        git push origin "$current_branch"
        echo "✅ Changes pushed."
        ;;
    pull)
        echo "📥 Pulling updates from Git Source of Truth..."
        if [[ "$dry_run" -eq 1 ]]; then
            echo "🧪 Dry run: would pull --rebase and run caf-system-rebuild."
            exit 0
        fi
        current_branch="$(git rev-parse --abbrev-ref HEAD)"
        if ! git pull --rebase origin "$current_branch"; then
            echo "⚠️  Rebase conflict detected."
            echo "Run these steps to recover:"
            echo "  git status"
            echo "  git rebase --continue   # after resolving files"
            echo "  or git rebase --abort   # to cancel"
            exit 1
        fi
        echo "🔨 Applying changes..."
        caf-system-rebuild
        echo "✅ Sync complete."
        ;;
    *)
        echo "Usage: caf-sync [push|pull] [--dry-run]"
        exit 1
        ;;
esac

end_ms="$(now_ms)"
echo "⏱️  Sync completed in $((end_ms - start_ms))ms"
