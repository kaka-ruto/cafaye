#!/bin/bash
set -euo pipefail

# --- Reliability Helpers ---
with_retry() {
    local max_attempts=3
    local timeout=2
    local attempt=1
    local exitCode=0

    while [ $attempt -le $max_attempts ]; do
        if "$@"; then
            return 0
        else
            exitCode=$?
            echo "⚠️  Command failed (attempt $attempt/$max_attempts). Retrying in $timeout seconds..."
            sleep $timeout
            attempt=$((attempt + 1))
            timeout=$((timeout * 2))
        fi
    done

    # Don't exit if it fails, just return the code
    return $exitCode
}

# Cafaye Fleet Management
# Usage: caf-fleet [status|add|sync|apply|attach|switch] [--resume]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_REPO_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SECRETS_DIR="${LOCAL_REPO_DIR}/secrets"
FLEET_YAML="${SECRETS_DIR}/fleet.yaml"

# Trace ID for cross-node correlation
export CAFAYE_TRACE_ID="caf-$(date +%s)-$RANDOM"

# Structured Logging
LOG_DIR="$HOME/.config/cafaye/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/fleet.log"
LOG_LEVEL="${CAFAYE_LOG_LEVEL:-info}" # quiet|info|debug
# We only redirect for heavy operations, not status.
if [[ "${1:-}" != "status" ]] && [[ "${1:-}" != "" ]]; then
    if [[ "$LOG_LEVEL" == "quiet" ]]; then
        exec >>"$LOG_FILE" 2>&1
    else
        exec > >(tee -a "$LOG_FILE") 2>&1
    fi
    [[ "$LOG_LEVEL" == "debug" ]] && set -x
    echo "--- Fleet $1 started: $(date) [Trace: $CAFAYE_TRACE_ID] [level: $LOG_LEVEL] ---"
fi

CAFAYE_DIR=""
if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    CAFAYE_DIR="$git_root"
elif [[ -f "${LOCAL_REPO_DIR}/flake.nix" && -d "${LOCAL_REPO_DIR}/cli/scripts" ]]; then
    CAFAYE_DIR="$LOCAL_REPO_DIR"
elif [[ -d "$HOME/.config/cafaye" ]]; then
    CAFAYE_DIR="$HOME/.config/cafaye"
else
    echo "❌ Could not locate Cafaye repository. Expected git checkout or ~/.config/cafaye."
    exit 1
fi

cd "$CAFAYE_DIR" || exit 1

command="${1:-}"
RESUME=0
if [[ "${2:-}" == "--resume" ]]; then
    RESUME=1
fi

SSH_COMMON_OPTS="-o BatchMode=yes -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new"

# Identify the SSH key for SOPS
SSH_PRIVATE_KEY=""
[[ -f "$HOME/.ssh/id_ed25519" ]] && SSH_PRIVATE_KEY="$HOME/.ssh/id_ed25519"
[[ -z "$SSH_PRIVATE_KEY" && -f "$HOME/.ssh/id_rsa" ]] && SSH_PRIVATE_KEY="$HOME/.ssh/id_rsa"

# Ensure SOPS_AGE_KEY is set
if [[ -n "$SSH_PRIVATE_KEY" && -z "${SOPS_AGE_KEY:-}" ]]; then
    if command -v ssh-to-age &> /dev/null; then
        export SOPS_AGE_KEY=$(ssh-to-age -private-key -i "$SSH_PRIVATE_KEY" 2>/dev/null)
    fi
fi

# Fallback if still empty
if [[ -n "$SSH_PRIVATE_KEY" && -z "${SOPS_AGE_KEY:-}" ]]; then
    export SOPS_AGE_KEY="$(nix --extra-experimental-features "nix-command flakes" shell nixpkgs#ssh-to-age --command ssh-to-age -private-key -i "$SSH_PRIVATE_KEY" 2>/dev/null || true)"
fi

# Layered decryption helper
run_sops() {
    # If sops is not in path, use nix run
    if command -v sops &> /dev/null; then
        sops "$@"
    else
        nix --extra-experimental-features "nix-command flakes" shell nixpkgs#sops --command sops "$@"
    fi
}

# Cross-platform reachability check
check_reachable() {
    local ip="$1"
    if [[ "$(uname -s)" == "Darwin" ]]; then
        # macOS ping uses -W in milliseconds
        ping -c 1 -W 1000 "$ip" >/dev/null 2>&1
    else
        # Linux ping uses -W in seconds (usually)
        ping -c 1 -W 1 "$ip" >/dev/null 2>&1
    fi
}

show_fleet_status() {
    local local_node
    local_node="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown)"
    echo "📋 Cafaye Fleet Dashboard"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    if [[ -z "${CAFAYE_FLEET_JSON:-}" ]] && [[ ! -f "secrets/fleet.yaml" ]]; then
      echo "Registry empty."
      return
    fi

    echo "Nodes:"
    # Use JSON output for jq
    if [[ -n "${CAFAYE_FLEET_JSON:-}" ]]; then
      DATA="$CAFAYE_FLEET_JSON"
    else
      DATA=$(run_sops -d --output-type json secrets/fleet.yaml 2>/dev/null)
    fi
    if [[ -z "$DATA" ]]; then
         echo "❌ Unable to decrypt/parse fleet registry."
    else
         echo "$DATA" | jq -r '.fleet | to_entries[] | "\(.key)|\(.value.tailscale_ip)|\(.value.role)|\(.value.hostname // .key)"' | while IFS='|' read -r name ip role host; do
             marker=""
             if [[ "$host" == "$local_node" || "$name" == "$local_node" ]]; then
                 marker=" [current]"
             fi
             echo "  - ${name}: ip=${ip} role=${role} host=${host}${marker}"
         done
         echo ""
         echo "Connectivity:"
         echo "$DATA" | jq -r '.fleet | to_entries[] | @base64' | while read -r row; do
             entry="$(echo "$row" | base64 --decode)"
             name="$(echo "$entry" | jq -r '.key')"
             ip="$(echo "$entry" | jq -r '.value.tailscale_ip')"
             
             if [[ "${CAFAYE_FLEET_NO_PROBE:-0}" == "1" ]]; then
                 echo "  - ${name}: probe-skipped"
                 continue
             fi
             if check_reachable "$ip"; then
                 echo "  - ${name}: reachable"
                 # Try to get more info via SSH if possible (batch mode to avoid hanging/prompting)
                 SSH_OPTS="-o ConnectTimeout=2 ${SSH_COMMON_OPTS}"
                 [[ -f "$HOME/.ssh/cafaye" ]] && SSH_OPTS="${SSH_OPTS} -i $HOME/.ssh/cafaye"
                 
                 proj="$(ssh ${SSH_OPTS} "$ip" 'jq -r ".current // \"none\"" ~/.config/cafaye/projects.json 2>/dev/null || echo n/a' 2>/dev/null || echo n/a)"
                 echo "    project: ${proj}"
                 sync="$(ssh ${SSH_OPTS} "$ip" 'cd ~/.config/cafaye 2>/dev/null && git status --porcelain 2>/dev/null | wc -l || echo n/a' 2>/dev/null || echo n/a)"
                 if [[ "$sync" == "0" ]]; then
                   echo "    sync: clean"
                 elif [[ "$sync" == "n/a" ]]; then
                   echo "    sync: unavailable"
                 else
                   echo "    sync: pending(${sync})"
                 fi
             else
                 echo "  - ${name}: unreachable"
             fi
         done
    fi
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

add_fleet_node() {
    name="${2:-}"; key="${3:-}"; ip="${4:-}"; role="${5:-remote}"
    if [[ -z "$name" || -z "$key" || -z "$ip" ]]; then
        echo "Usage: caf fleet add <name> <age-key> <tailscale-ip> [role]"
        exit 1
    fi
    if [[ ! "$key" =~ ^age1[0-9a-z]+$ ]]; then
        echo "❌ Invalid age recipient key: '$key'"
        echo "Expected format: age1..."
        exit 1
    fi
    echo "💾 Adding node '$name' to fleet..."
    
    if [[ -f ".sops.yaml" ]] && ! grep -q "$key" .sops.yaml; then
        echo "🔑 Authorizing node key in .sops.yaml..."
        [[ "$(uname -s)" == "Darwin" ]] && sed -i "" "/- \"age1/a\\
          - \"$key\"" .sops.yaml || sed -i "/- \"age1/a \          - \"$key\"" .sops.yaml
    fi

    mkdir -p secrets
    tmp_plain="$(mktemp)"
    tmp_new="$(mktemp)"
    trap 'rm -f "$tmp_plain" "$tmp_new"' EXIT

    if [[ -s "secrets/fleet.yaml" ]] && run_sops -d --output-type json secrets/fleet.yaml >"$tmp_plain" 2>/dev/null; then
      :
    else
      echo "⚠️  Existing fleet registry is invalid or undecryptable. Reinitializing..."
      cp secrets/fleet.yaml "secrets/fleet.yaml.broken.$(date +%s)" 2>/dev/null || true
      echo '{"fleet":{}}' >"$tmp_plain"
    fi

    jq ".fleet[\"$name\"] = {\"tailscale_ip\":\"$ip\",\"role\":\"$role\",\"hostname\":\"$name\"}" "$tmp_plain" >"$tmp_new"

    echo "🔄 Updating encrypted registry..."
    run_sops -e --input-type json --output-type yaml --filename-override secrets/fleet.yaml "$tmp_new" > secrets/fleet.yaml

    echo "✅ Node '$name' added."
}

remove_fleet_node() {
    name="${2:-}"
    if [[ -z "$name" ]]; then
        echo "Usage: caf fleet remove <name>"
        exit 1
    fi
    echo "🗑️  Removing node '$name' from fleet..."

    mkdir -p secrets
    tmp_plain="$(mktemp)"
    tmp_new="$(mktemp)"
    trap 'rm -f "$tmp_plain" "$tmp_new"' EXIT

    if [[ -s "secrets/fleet.yaml" ]] && run_sops -d --output-type json secrets/fleet.yaml >"$tmp_plain" 2>/dev/null; then
       # check if exists
       if [[ $(jq "(.fleet | has(\"$name\"))" "$tmp_plain") == "false" ]]; then
           echo "❌ Node '$name' not found in registry."
           exit 1
       fi
       jq "del(.fleet[\"$name\"])" "$tmp_plain" > "$tmp_new"
       run_sops -e --input-type json --output-type yaml --filename-override secrets/fleet.yaml "$tmp_new" > secrets/fleet.yaml
       echo "✅ Node '$name' removed from registry."
    else
       echo "❌ Registry empty or inaccessible."
       exit 1
    fi
}

fleet_apply() {
    echo "🚀 Orchestrating fleet-wide apply..."
    mapfile -t remotes < <(run_sops -d --output-type json secrets/fleet.yaml 2>/dev/null | jq -r '.fleet | to_entries[] | select(.value.role == "remote") | .value.tailscale_ip')
    [[ "${#remotes[@]}" -eq 0 ]] && { echo "No remote nodes found."; return; }

    SSH_OPT=""
    [[ -f "$HOME/.ssh/cafaye" ]] && SSH_OPT="-i $HOME/.ssh/cafaye"
    remote_opts="-o ConnectTimeout=5 ${SSH_COMMON_OPTS}"

    state_dir="$HOME/.config/cafaye/state"
    mkdir -p "$state_dir"
    state_file="$state_dir/fleet-apply.state"
    [[ "$RESUME" -eq 0 ]] && : > "$state_file"
    is_completed() {
      local host="$1"
      grep -Fxq "$host" "$state_file" 2>/dev/null
    }

    cancelled=0
    trap 'cancelled=1; echo "⚠️  Cancel requested. You can resume with: caf-fleet apply --resume"' INT TERM

    total="${#remotes[@]}"
    index=0
    ok=0
    failed=0
    for remote in "${remotes[@]}"; do
        index=$((index + 1))
        if is_completed "$remote"; then
            echo "⏭️  [${index}/${total}] Skipping already completed node $remote (--resume)."
            continue
        fi
        [[ "$cancelled" -eq 1 ]] && break
        echo "🛠️  [${index}/${total}] Applying on $remote (trace: $CAFAYE_TRACE_ID)..."
        if with_retry ssh $SSH_OPT $remote_opts "$remote" "export CAFAYE_TRACE_ID=$CAFAYE_TRACE_ID && caf apply"; then
            echo "$remote" >> "$state_file"
            ok=$((ok + 1))
            echo "✅ Applied on $remote"
        else
            failed=$((failed + 1))
            echo "❌ Failed to reach/apply on $remote"
        fi
    done
    trap - INT TERM
    echo "📊 Apply summary: success=$ok failed=$failed total=$total"
    [[ "$cancelled" -eq 1 || "$failed" -gt 0 ]] && return 1 || return 0
}

fleet_sync() {
    echo "📦 Syncing local codebase to all remote nodes..."
    mapfile -t remotes < <(run_sops -d --output-type json secrets/fleet.yaml 2>/dev/null | jq -r '.fleet | to_entries[] | select(.value.role == "remote") | .value.tailscale_ip')
    [[ "${#remotes[@]}" -eq 0 ]] && { echo "No remote nodes found."; return; }

    SSH_OPT=""
    [[ -f "$HOME/.ssh/cafaye" ]] && SSH_OPT="-i $HOME/.ssh/cafaye"

    state_dir="$HOME/.config/cafaye/state"
    mkdir -p "$state_dir"
    state_file="$state_dir/fleet-sync.state"
    [[ "$RESUME" -eq 0 ]] && : > "$state_file"
    is_completed() {
      local host="$1"
      grep -Fxq "$host" "$state_file" 2>/dev/null
    }

    cancelled=0
    trap 'cancelled=1; echo "⚠️  Cancel requested. You can resume with: caf-fleet sync --resume"' INT TERM

    total="${#remotes[@]}"
    index=0
    ok=0
    failed=0
    for remote in "${remotes[@]}"; do
        index=$((index + 1))
        if is_completed "$remote"; then
            echo "⏭️  [${index}/${total}] Skipping already completed node $remote (--resume)."
            continue
        fi
        [[ "$cancelled" -eq 1 ]] && break
        echo "📤 [${index}/${total}] Syncing to $remote..."
        if with_retry rsync -avz --delete-delay --exclude '.git' --exclude '.devbox' --exclude '.cache' --exclude 'result' \
            -e "ssh $SSH_OPT $SSH_COMMON_OPTS" \
            ./ "$(whoami)@${remote}:~/.config/cafaye/"; then
             echo "$remote" >> "$state_file"
             ok=$((ok + 1))
             echo "✅ Synced $remote"
        else
             failed=$((failed + 1))
             echo "❌ Failed to sync $remote"
        fi
    done
    trap - INT TERM
    echo "📊 Sync summary: success=$ok failed=$failed total=$total"
    [[ "$cancelled" -eq 1 || "$failed" -gt 0 ]] && return 1 || return 0
}

fleet_attach() {
    local session="fleet"
    local data
    data="$(run_sops -d --output-type json secrets/fleet.yaml 2>/dev/null || echo '{}')"
    if [[ -z "$data" || "$data" == "{}" ]]; then
      echo "No fleet registry found."
      return 1
    fi
    tmux kill-session -t "$session" >/dev/null 2>&1 || true
    tmux new-session -d -s "$session" -n overview
    tmux send-keys -t "${session}:overview" "watch -n 5 caf-fleet status" C-m

    echo "$data" | jq -r '.fleet | to_entries[] | "\(.key)|\(.value.tailscale_ip)"' | while IFS='|' read -r name ip; do
      node_session="node-${name}"
      tmux kill-session -t "$node_session" >/dev/null 2>&1 || true
      tmux new-session -d -s "$node_session" -n "$name" "echo '[${name}]'; ssh $SSH_COMMON_OPTS ${ip}"
      tmux new-window -t "${session}:" -n "$name" "tmux attach -t ${node_session}"
    done
    tmux attach -t "$session"
}

fleet_switch() {
    local target
    if command -v fzf >/dev/null 2>&1; then
      target="$(tmux list-sessions -F '#S' | fzf --height=40% --reverse --prompt='session> ' || true)"
    else
      target="$(tmux list-sessions -F '#S' | head -n1)"
    fi
    [[ -z "$target" ]] && { echo "No tmux sessions found."; return 1; }
    tmux switch-client -t "$target" 2>/dev/null || tmux attach -t "$target"
}

case "$command" in
    status) show_fleet_status ;;
    add) add_fleet_node "$@" ;;
    remove) remove_fleet_node "$@" ;;
    sync) fleet_sync ;;
    apply) fleet_apply ;;
    attach) fleet_attach ;;
    switch) fleet_switch ;;
    *) echo "Usage: caf fleet [status|add|remove|sync|apply|attach|switch] [--resume]"; exit 1 ;;
esac
