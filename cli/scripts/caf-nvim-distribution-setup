#!/bin/bash
set -euo pipefail

# Cafaye OS Neovim Distribution Setup
# Sets up the selected distribution with Cafaye theming

NVIM_CONFIG="$HOME/.config/nvim"
BACKUP_DIR="$HOME/.config/nvim-backup-$(date +%Y%m%d%H%M%S)"
MARKER_FILE="$HOME/.config/nvim/.cafaye-distro"
MODE="setup" # setup|doctor|repair

while [[ $# -gt 0 ]]; do
  case "$1" in
    --doctor) MODE="doctor" ;;
    --repair) MODE="repair" ;;
    *) echo "Usage: caf-nvim-distribution-setup [--doctor|--repair]"; exit 1 ;;
  esac
  shift
done

# Get active distribution
get_active_distribution() {
    for dist in lazyvim astronvim nvchad lunarvim; do
        val=$(caf-state-read "editors.distributions.nvim.$dist" 2>/dev/null)
        if [[ "$val" == "true" ]]; then
            echo "$dist"
            return
        fi
    done
    echo "none"
}

distribution=$(get_active_distribution)
CAFAYE_REPO="${HOME}/.config/cafaye"

plugin_health_check() {
    local ok=1
    local marker_dist="unknown"
    [[ -f "$MARKER_FILE" ]] && marker_dist="$(cat "$MARKER_FILE" 2>/dev/null || echo unknown)"
    echo "🩺 Neovim plugin health check"
    echo "  selected distribution: $distribution"
    echo "  marker distribution:   $marker_dist"

    if [[ ! -d "$NVIM_CONFIG" ]]; then
        echo "  ❌ Missing $NVIM_CONFIG"
        ok=0
    fi
    if [[ ! -d "$HOME/.local/share/nvim" ]]; then
        echo "  ⚠️  Missing ~/.local/share/nvim (plugins may not be installed yet)"
    fi
    if [[ "$distribution" == "lazyvim" || "$distribution" == "astronvim" ]]; then
        if [[ ! -f "$NVIM_CONFIG/lazy-lock.json" ]]; then
            echo "  ⚠️  Missing lazy-lock.json (plugins may need bootstrap)"
        fi
    fi
    if [[ "$distribution" == "none" ]]; then
        echo "  ❌ No active Neovim distribution selected."
        ok=0
    fi

    if [[ "$ok" -eq 1 ]]; then
        echo "✅ Plugin health looks recoverable."
        return 0
    else
        echo "❌ Plugin state appears broken."
        return 1
    fi
}

repair_plugin_state() {
    echo "🧹 Repairing Neovim runtime/plugin state..."
    rm -rf "$HOME/.local/share/nvim" "$HOME/.local/state/nvim" "$HOME/.cache/nvim"
    mkdir -p "$NVIM_CONFIG"
    echo "✅ Runtime caches cleared. Re-run setup/bootstrap by launching nvim."
}

if [[ "$distribution" == "none" ]]; then
    echo "❌ No distribution selected. Run: caf-editor-distribution-set nvim <distribution>"
    exit 1
fi

if [[ "$MODE" == "doctor" ]]; then
    plugin_health_check
    exit $?
fi

if [[ "$MODE" == "repair" ]]; then
    repair_plugin_state
    plugin_health_check || true
    exit 0
fi

echo "🔧 Setting up $distribution..."

# Backup existing config
if [[ -d "$NVIM_CONFIG" ]]; then
    echo "📦 Backing up existing config to $BACKUP_DIR"
    mv "$NVIM_CONFIG" "$BACKUP_DIR"
fi

case "$distribution" in
    lazyvim)
        echo "📥 Cloning LazyVim starter..."
        git clone https://github.com/LazyVim/starter "$NVIM_CONFIG" --depth 1
        rm -rf "$NVIM_CONFIG/.git"
        
        # Copy Cafaye user-layer defaults when available
        if [[ -f "${CAFAYE_REPO}/config/user/nvim/lazyvim/plugins/user.lua" ]]; then
            cp "${CAFAYE_REPO}/config/user/nvim/lazyvim/plugins/user.lua" \
               "$NVIM_CONFIG/lua/plugins/user.lua"
        fi
        ;;
        
    astronvim)
        echo "📥 AstroNvim Configuration..."
        echo "ℹ️  AstroNvim v5+ is managed declaratively via Home Manager."
        echo "    Skipping template clone to avoid conflicts."
        # Ensure directory is empty so HM can link files
        rm -rf "$NVIM_CONFIG"
        mkdir -p "$NVIM_CONFIG"
        ;;
        
    nvchad)
        echo "📥 Cloning NvChad..."
        git clone https://github.com/NvChad/starter "$NVIM_CONFIG" --depth 1
        rm -rf "$NVIM_CONFIG/.git"
        
        if [[ -f "${CAFAYE_REPO}/config/user/nvim/nvchad/chadrc.lua" ]]; then
            cp "${CAFAYE_REPO}/config/user/nvim/nvchad/chadrc.lua" \
               "$NVIM_CONFIG/lua/chadrc.lua"
        fi
        ;;
        
    lunarvim)
        echo "📥 Installing LunarVim..."
        # LunarVim has its own installer
        LV_BRANCH='release-1.4/neovim-0.9' bash <(curl -s https://raw.githubusercontent.com/LunarVim/LunarVim/release-1.4/neovim-0.9/utils/installer/install.sh) -y
        
        if [[ -f "${CAFAYE_REPO}/config/user/nvim/lunarvim/config.lua" ]]; then
            cp "${CAFAYE_REPO}/config/user/nvim/lunarvim/config.lua" \
               "$HOME/.config/lvim/config.lua"
        fi
        ;;
esac

# Mark active distro for downstream tooling.
mkdir -p "$NVIM_CONFIG"
echo "$distribution" > "$MARKER_FILE"

# Keep user override path visible from standard lua/user location.
mkdir -p "$NVIM_CONFIG/lua"
ln -sfn "$HOME/.config/cafaye/config/user/nvim/$distribution" "$NVIM_CONFIG/lua/user"

echo "✅ $distribution configured with Catppuccin theme!"
echo ""
echo "💡 Launch with: nvim"
echo "📝 User overrides: $NVIM_CONFIG/lua/plugins/"

caf-task-done "Nvim Distribution Setup"
